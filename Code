                )}

                {script && !loading && (
                  <>
                    <div style={{ display: "flex", justifyContent: "flex-end", marginBottom: 20, gap: 8 }}>
                      <button className="btn btn-outline" style={{ fontSize: 13, padding: "7px 16px" }} onClick={() => generateScript(selectedDay)}>
                        ↻ Regenerate
                      </button>
                      <button className="btn btn-pink" style={{ fontSize: 13, padding: "7px 16px" }} onClick={copyScript}>
                        {copied ? "✓ Copied!" : "Copy script"}
                      </button>
                    </div>
                    <div className="script-block">{formatScript(script)}</div>
                    <div style={{ marginTop: 24, padding: "16px", background: "rgba(232,164,184,0.1)", borderRadius: 10, borderLeft: "3px solid #e8a4b8" }}>
                      <div className="ui" style={{ fontSize: 11, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.1em", color: "#c490a8", marginBottom: 6 }}>Caption ready to use</div>
                      <div className="ui" style={{ fontSize: 14, color: "#3a2030", fontStyle: "italic" }}>{selectedDay.caption}</div>
                    </div>
                  </>
                )}
              </div>

              {/* Navigation */}
              {script && !loading && (
                <div style={{ display: "flex", gap: 10, marginTop: 20, justifyContent: "flex-end" }}>
                  {selectedDay.day > 1 && (
                    <button className="btn btn-outline" onClick={() => generateScript(CONTENT_BANK[selectedDay.day - 2])}>
                      ← Day {selectedDay.day - 1}
                    </button>
                  )}
                  {selectedDay.day < 150 && (
                    <button className="btn btn-pink" onClick={() => generateScript(CONTENT_BANK[selectedDay.day])}>
                      Day {selectedDay.day + 1} →
                    </button>
                  )}
                </div>
              )}
            </>
          )}
        </div>
      </div>
    </div>
  );
}

function formatScript(text) {
  // Render the script with styled sections
  const lines = text.split("\n");
  return lines.map((line, i) => {
    const trimmed = line.trim();
    if (!trimmed) return <br key={i} />;

    const isSectionHeader = /^(HOOK|BODY|CLOSE|OPENING|INTRO|OUTRO|SECTION|PART)/i.test(trimmed) && trimmed.length < 40;
    const isCue = /^\[.*\]$/.test(trimmed);
    const isBold = /^\*\*.*\*\*$/.test(trimmed) || /^#{1,3}\s/.test(trimmed);

    if (isSectionHeader) {
      return (
        <div key={i} style={{ fontFamily: "'Outfit', sans-serif", fontSize: 10, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.2em", color: "#c490a8", marginTop: 22, marginBottom: 10 }}>
          — {trimmed.replace(/[:#*]/g, "").trim()} —
        </div>
      );
    }
    if (isCue) {
      return (
        <div key={i} style={{ fontFamily: "'Outfit', sans-serif", fontSize: 12, color: "#9070a0", fontStyle: "italic", margin: "6px 0", paddingLeft: 12, borderLeft: "2px solid rgba(196,160,212,0.4)" }}>
          {trimmed}
        </div>
      );
    }
    const cleanLine = trimmed.replace(/^\*\*|\*\*$/g, "").replace(/^#{1,3}\s/, "");
    return (
      <p key={i} style={{ fontFamily: "'Outfit', sans-serif", fontSize: 15, lineHeight: 1.85, color: "#1e1420", marginBottom: 10 }}>
        {cleanLine}
      </p>
    );
