<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Script Generator — 150-Day Content System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Cormorant Garamond', Georgia, serif;
      background: #fdf8fc;
      color: #1e1420;
      min-height: 100vh;
    }

    .ui {
      font-family: 'Outfit', sans-serif;
    }

    ::-webkit-scrollbar {
      width: 4px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: #e8a4b8;
      border-radius: 2px;
    }

    /* Header */
    .header {
      background: linear-gradient(135deg, #fdf0f6 0%, #f5effe 60%, #eef4fd 100%);
      border-bottom: 1px solid rgba(200, 150, 180, 0.15);
      padding: 28px 24px 20px;
    }

    .header-content {
      max-width: 1200px;
      margin: 0 auto;
    }

    .header-label {
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #c490a8;
      margin-bottom: 6px;
      font-weight: 600;
    }

    h1 {
      font-size: clamp(24px, 4vw, 38px);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 8px;
    }

    .gradient-text {
      background: linear-gradient(135deg, #c4609a, #9070d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .header-description {
      color: #7a5068;
      font-size: 14px;
      max-width: 520px;
      line-height: 1.7;
    }

    /* Layout */
    .container {
      display: flex;
      max-width: 1200px;
      margin: 0 auto;
      min-height: calc(100vh - 120px);
    }

    /* Sidebar */
    .sidebar {
      width: 420px;
      border-right: 1px solid rgba(200, 150, 180, 0.15);
      display: flex;
      flex-direction: column;
      background: white;
    }

    .filters {
      padding: 16px 16px 12px;
      border-bottom: 1px solid rgba(200, 150, 180, 0.1);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .search-wrapper {
      position: relative;
    }

    .search-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #c490a8;
      font-size: 14px;
    }

    .search-input {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      padding: 8px 14px 8px 36px;
      border: 1.5px solid rgba(232, 164, 184, 0.35);
      border-radius: 10px;
      background: white;
      color: #4a2a3a;
      outline: none;
      width: 200px;
      transition: width 0.2s;
    }

    .search-input:focus {
      border-color: #e8a4b8;
      width: 240px;
    }

    .filter-selects {
      display: flex;
      gap: 8px;
    }

    .filter-select {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      padding: 8px 12px;
      border: 1.5px solid rgba(232, 164, 184, 0.35);
      border-radius: 10px;
      background: white;
      color: #4a2a3a;
      outline: none;
      cursor: pointer;
      flex: 1;
    }

    .filter-select:focus {
      border-color: #e8a4b8;
    }

    .filter-count {
      font-size: 12px;
      color: #b090a0;
    }

    /* Day list */
    .day-list {
      flex: 1;
      overflow-y: auto;
      padding: 10px 12px;
    }

    .day-row {
      display: grid;
      grid-template-columns: 48px 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 14px 16px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.15s;
      border: 1.5px solid transparent;
    }

    .day-row:hover {
      background: rgba(232, 164, 184, 0.1);
      border-color: rgba(232, 164, 184, 0.3);
    }

    .day-row.active {
      background: rgba(232, 164, 184, 0.15);
      border-color: #e8a4b8;
    }

    .day-number {
      text-align: center;
    }

    .day-number-value {
      font-size: 17px;
      font-weight: 700;
      color: #2a1a24;
    }

    .day-row.active .day-number-value {
      color: #c4609a;
    }

    .day-label {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #c0a0b0;
    }

    .day-content {
      flex: 1;
    }

    .day-hook {
      font-size: 13px;
      font-style: italic;
      line-height: 1.4;
      margin-bottom: 5px;
      color: #3a2030;
    }

    .day-row.active .day-hook {
      color: #1e1420;
    }

    .day-tags {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      font-family: 'Outfit', sans-serif;
      letter-spacing: 0.03em;
      color: #6a3050;
    }

    .day-arrow {
      font-size: 18px;
      color: #d4b8c4;
    }

    .day-row.active .day-arrow {
      color: #e8a4b8;
    }

    /* Pagination */
    .pagination {
      padding: 12px 16px;
      border-top: 1px solid rgba(200, 150, 180, 0.1);
      display: flex;
      gap: 6px;
      justify-content: center;
    }

    .btn {
      padding: 10px 20px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.15s;
    }

    .btn-pink {
      background: linear-gradient(135deg, #e8a4b8, #d490c8);
      color: white;
      box-shadow: 0 2px 12px rgba(232, 164, 184, 0.4);
    }

    .btn-pink:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(232, 164, 184, 0.5);
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid rgba(232, 164, 184, 0.5);
      color: #8b5070;
    }

    .btn-outline:hover {
      background: rgba(232, 164, 184, 0.1);
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .btn-small {
      padding: 6px 14px;
      font-size: 13px;
    }

    .btn-mini {
      padding: 6px 12px;
      font-size: 13px;
      min-width: 34px;
    }

    /* Main content */
    .main {
      flex: 1;
      padding: 28px 32px;
      overflow-y: auto;
      min-height: 600px;
    }

    /* Empty state */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      min-height: 400px;
      text-align: center;
      gap: 16px;
    }

    .empty-icon {
      font-size: 48px;
    }

    .empty-title {
      font-size: 24px;
      font-weight: 600;
      color: #2a1a24;
    }

    .empty-description {
      color: #8b6070;
      font-size: 15px;
      max-width: 380px;
      line-height: 1.7;
    }

    .quick-buttons {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 8px;
    }

    /* Day header */
    .day-header {
      margin-bottom: 24px;
    }

    .day-meta {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .day-badge {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #c490a8;
    }

    .day-hook-title {
      font-size: clamp(18px, 3vw, 26px);
      font-style: italic;
      font-weight: 600;
      line-height: 1.3;
      color: #1e1420;
      margin-bottom: 8px;
    }

    .day-concept {
      font-size: 13px;
      color: #7a5068;
      line-height: 1.6;
    }

    /* Script output */
    .script-container {
      background: linear-gradient(135deg, #fdf8fc, #f8f4fd);
      border-radius: 16px;
      border: 1.5px solid rgba(200, 150, 180, 0.2);
      padding: 28px;
      min-height: 280px;
    }

    .script-actions {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 20px;
      gap: 8px;
    }

    .script-block {
      white-space: pre-wrap;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      line-height: 1.9;
      color: #2a1a24;
    }

    .script-block strong,
    .script-block b {
      color: #c4609a;
    }

    .section-header {
      font-family: 'Outfit', sans-serif;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #c490a8;
      margin-top: 22px;
      margin-bottom: 10px;
    }

    .script-cue {
      font-family: 'Outfit', sans-serif;
      font-size: 12px;
      color: #9070a0;
      font-style: italic;
      margin: 6px 0;
      padding-left: 12px;
      border-left: 2px solid rgba(196, 160, 212, 0.4);
    }

    .script-line {
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      line-height: 1.85;
      color: #1e1420;
      margin-bottom: 10px;
    }

    .caption-box {
      margin-top: 24px;
      padding: 16px;
      background: rgba(232, 164, 184, 0.1);
      border-radius: 10px;
      border-left: 3px solid #e8a4b8;
    }

    .caption-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #c490a8;
      margin-bottom: 6px;
    }

    .caption-text {
      font-size: 14px;
      color: #3a2030;
      font-style: italic;
    }

    /* Loading */
    .loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      padding: 40px 0;
    }

    .loading-dots {
      display: flex;
      gap: 6px;
    }

    .loading-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #e8a4b8;
      animation: pulse 1.2s infinite;
    }

    .loading-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .loading-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes pulse {
      0%, 80%, 100% {
        opacity: 0.2;
        transform: scale(0.8);
      }
      40% {
        opacity: 1;
        transform: scale(1);
      }
    }

    .loading-text {
      color: #b090a0;
      font-size: 14px;
    }

    /* Error */
    .error-message {
      text-align: center;
      padding: 40px 0;
    }

    .error-text {
      color: #e88090;
      margin-bottom: 16px;
    }

    /* Navigation */
    .script-nav {
      display: flex;
      gap: 10px;
      margin-top: 20px;
      justify-content: flex-end;
    }

    /* Responsive */
    @media (max-width: 700px) {
      .container {
        flex-direction: column;
      }

      .sidebar {
        width: 100%;
        max-height: 40vh;
      }

      .main {
        min-height: unset;
      }
    }
  </style>
</head>
<body>
  <div id="app"></div>

  <script>
    // Content bank data
    const CONTENT_BANK = [
      { day: 1, pillar: "becoming", phase: "Foundation", hook: "I don't have it figured out. But I'm figuring it out.", concept: "Intro video — not a 'this is my channel' video. Just a day. Let the aesthetic speak.", format: "vlog snippet", caption: "day 1 of becoming", cta: "Follow along for the full journey" },
      { day: 2, pillar: "aesthetic", phase: "Foundation", hook: "My morning before anyone else wakes up.", concept: "5am or early morning routine. No talking. Soft light, coffee, notebook, quiet.", format: "aesthetic montage", caption: "5am is my creative hour", cta: "Save this time for yourself" },
      { day: 3, pillar: "ambition", phase: "Foundation", hook: "Computer engineering is not what people think it is.", concept: "1-minute debunk. Soft, confident. Your aesthetic stays strong throughout.", format: "talking-head", caption: "breaking stereotypes in tech", cta: "More on this coming" },
      { day: 4, pillar: "becoming", phase: "Foundation", hook: "Building the version of myself I actually want to be.", concept: "Phone notes dump — your actual goals, written raw. Voice over reading them.", format: "voiceover", caption: "the version i'm building", cta: "What's on your list?" },
      { day: 5, pillar: "aesthetic", phase: "Foundation", hook: "The details that make an ordinary day feel beautiful.", concept: "Micro-moments montage. Candle, lip gloss, clean desk, journal. No narration.", format: "aesthetic montage", caption: "beauty in the details", cta: "Notice the small things today" },
      { day: 6, pillar: "ambition", phase: "Foundation", hook: "What studying computer engineering actually looks like for me.", concept: "Honest 'a day studying' — not glamorized, not messy. Real, but aesthetic.", format: "vlog snippet", caption: "a day in engineering", cta: "If you're thinking about this path..." },
      { day: 7, pillar: "becoming", phase: "Foundation", hook: "The gap between where I am and where I'm going.", concept: "Reflection video. 60 seconds. What you're working toward. Not sad — energized.", format: "talking-head", caption: "the becoming phase", cta: "What's your gap?" },
      { day: 8, pillar: "aesthetic", phase: "Foundation", hook: "GRWM for a day I'm not excited about.", concept: "Honest GRWM. Get ready for a long day of classes. Voiceover on how you use getting ready as a reset.", format: "GRWM", caption: "getting ready when i'd rather not", cta: "Getting ready is a ritual, not a chore" },
      { day: 9, pillar: "ambition", phase: "Foundation", hook: "My actual productivity system (it's not what influencers show).", concept: "Quick breakdown of how you manage assignments, energy, aesthetic. No fluff.", format: "talking-head", caption: "what actually works for me", cta: "Systems over motivation" },
      { day: 10, pillar: "becoming", phase: "Foundation", hook: "I stopped waiting to feel ready.", concept: "Short, punchy. The moment you started before you were confident. Relatable to every 18-year-old.", format: "talking-head", caption: "ready or not", cta: "When are you starting?" }
    ];

    // Add more days for brevity (showing only first 10 in this example)
    // In production, you'd load all 150 days

    const PILLAR_COLORS = {
      becoming: { bg: "#fde8f0", accent: "#e8a4b8", label: "💭 Becoming" },
      aesthetic: { bg: "#f5e8fd", accent: "#c4a0d4", label: "💅 Aesthetic" },
      ambition: { bg: "#e8effe", accent: "#a4b8e8", label: "📈 Ambition" },
    };

    const PHASE_COLORS = {
      Foundation: "#fde8f0",
      Depth: "#f5e8fd",
      Momentum: "#e8f0fd",
      Authority: "#e8fdf5",
    };

    const PERSONA_SYSTEM = `You are a script writer for a specific content creator. Write ONLY her script — nothing else.

CREATOR IDENTITY:
- Feminine, ambitious 18-year-old computer engineering student
- Building an "IT girl in the making" identity through lifestyle, mindset, and aesthetic storytelling
- NOT fully arrived. NOT pretending. Consciously becoming.
- Voice: soft, confident, direct. Never cringey, never performative, never fake-deep
- She speaks like a real girl who thinks a lot — not a motivational speaker
- The vibe is "calm confidence" + "romanticized real life" + "soft but clearly building something"

SCRIPT RULES:
1. Start with the hook line directly — no intro, no greeting
2. Keep it conversational, natural, like she's talking to a close friend on camera
3. No filler phrases: "honestly", "genuinely", "at the end of the day", "you know what I mean"
4. No toxic positivity or hollow affirmations
5. Specific > vague always. Real details > abstract ideas
6. For voiceover/B-roll: write the spoken words only. Add [b-roll: description] cues in brackets
7. For GRWM: write what she says while getting ready, with [doing: action] cues
8. For talking-head: write naturally spoken paragraphs, broken into beats
9. For vlog snippet: write voiceover narration + [scene: description] cues
10. For study-with-me: brief spoken intro + [silence/ambient] sections + end reflection
11. End with the CTA line naturally woven in — not announced as a CTA
12. Target length: 45–90 seconds of spoken word (approximately 120–220 words of dialogue)
13. Format the script clearly with a HOOK section, BODY section, and CLOSE section
14. The close should feel earned, not tacked on`;

    // State management
    let state = {
      selectedDay: null,
      script: "",
      loading: false,
      error: "",
      search: "",
      filterPillar: "all",
      filterPhase: "all",
      copied: false,
      page: 1,
      PER_PAGE: 25,
    };

    // Filter function
    function getFilteredDays() {
      return CONTENT_BANK.filter(d => {
        const matchPillar = state.filterPillar === "all" || d.pillar === state.filterPillar;
        const matchPhase = state.filterPhase === "all" || d.phase === state.filterPhase;
        const matchSearch = !state.search || d.hook.toLowerCase().includes(state.search.toLowerCase()) || String(d.day).includes(state.search);
        return matchPillar && matchPhase && matchSearch;
      });
    }

    function getPaginatedDays() {
      const filtered = getFilteredDays();
      return filtered.slice((state.page - 1) * state.PER_PAGE, state.page * state.PER_PAGE);
    }

    // Generate script
    async function generateScript(dayData) {
      state.selectedDay = dayData;
      state.script = "";
      state.error = "";
      state.loading = true;
      render();

      const mainEl = document.querySelector(".main");
      if (mainEl) {
        mainEl.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      const prompt = `Write a complete video script for Day ${dayData.day} of my content journey.

CONTENT DETAILS:
- Hook: "${dayData.hook}"
- Content concept: ${dayData.concept}
- Format: ${dayData.format}
- Content pillar: ${dayData.pillar}
- Phase: ${dayData.phase}
- Caption (for tone reference): "${dayData.caption}"
- CTA to weave in naturally: "${dayData.cta}"

Write the full script now. Use the exact format: HOOK / BODY / CLOSE sections. Include relevant cues for the format type. Make it feel real, specific, and like something she'd actually say.`;

      try {
        const res = await fetch("https://api.anthropic.com/v1/messages", {
          method: "POST",
          headers: { 
            "Content-Type": "application/json",
            "x-api-key": "sk-YOUR-API-KEY" // Replace with actual API key
          },
          body: JSON.stringify({
            model: "claude-sonnet-4-20250514",
            max_tokens: 1000,
            system: PERSONA_SYSTEM,
            messages: [{ role: "user", content: prompt }],
          }),
        });
        const data = await res.json();
        if (data.content?.[0]?.text) {
          state.script = data.content[0].text;
        } else {
          state.error = "Couldn't generate script. Try again.";
        }
      } catch (e) {
        state.error = "Network error. Try again. (Note: Add your Anthropic API key)";
      }
      state.loading = false;
      render();
    }

    function copyScript() {
      if (state.script) {
        navigator.clipboard.writeText(state.script);
        state.copied = true;
        render();
        setTimeout(() => {
          state.copied = false;
          render();
        }, 2000);
      }
    }

    // Format script helper
    function formatScriptHTML(text) {
      const lines = text.split("\n");
      return lines.map(line => {
        const trimmed = line.trim();
        if (!trimmed) return "<br>";

        const isSectionHeader = /^(HOOK|BODY|CLOSE|OPENING|INTRO|OUTRO|SECTION|PART)/i.test(trimmed) && trimmed.length < 40;
        const isCue = /^\[.*\]$/.test(trimmed);

        if (isSectionHeader) {
          return `<div class="section-header">— ${trimmed.replace(/[:#*]/g, "").trim()} —</div>`;
        }
        if (isCue) {
          return `<div class="script-cue">${trimmed}</div>`;
        }
        const cleanLine = trimmed.replace(/^\*\*|\*\*$/g, "").replace(/^#{1,3}\s/, "");
        return `<p class="script-line">${cleanLine}</p>`;
      }).join("");
    }

    // Render function
    function render() {
      const app = document.getElementById("app");
      const filtered = getFilteredDays();
      const totalPages = Math.ceil(filtered.length / state.PER_PAGE);
      const paginated = getPaginatedDays();

      let html = `
        <div class="header">
          <div class="header-content">
            <p class="header-label ui">150-Day Content System</p>
            <h1>Script Generator <span class="gradient-text">✦</span></h1>
            <p class="header-description ui">
              Select any of your 150 days and get a complete, on-brand script — written in your voice, for your format, for your audience.
            </p>
          </div>
        </div>

        <div class="container">
          <!-- Sidebar -->
          <div class="sidebar">
            <div class="filters">
              <div class="search-wrapper">
                <span class="search-icon">🔍</span>
                <input 
                  type="text" 
                  class="search-input ui" 
                  placeholder="Search by day or keyword..."
                  value="${state.search}"
                  onchange="handleSearchChange(this.value)"
                  oninput="handleSearchChange(this.value)"
                >
              </div>
              <div class="filter-selects">
                <select class="filter-select ui" onchange="handlePillarChange(this.value)">
                  <option value="all">All Pillars</option>
                  <option value="becoming" ${state.filterPillar === "becoming" ? "selected" : ""}>💭 Becoming</option>
                  <option value="aesthetic" ${state.filterPillar === "aesthetic" ? "selected" : ""}>💅 Aesthetic</option>
                  <option value="ambition" ${state.filterPillar === "ambition" ? "selected" : ""}>📈 Ambition</option>
                </select>
                <select class="filter-select ui" onchange="handlePhaseChange(this.value)">
                  <option value="all">All Phases</option>
                  <option value="Foundation" ${state.filterPhase === "Foundation" ? "selected" : ""}>Foundation</option>
                  <option value="Depth" ${state.filterPhase === "Depth" ? "selected" : ""}>Depth</option>
                  <option value="Momentum" ${state.filterPhase === "Momentum" ? "selected" : ""}>Momentum</option>
                  <option value="Authority" ${state.filterPhase === "Authority" ? "selected" : ""}>Authority</option>
                </select>
              </div>
              <div class="filter-count ui">${filtered.length} posts ${filtered.length < 150 ? `(filtered from 150)` : ""}</div>
            </div>

            <!-- Day list -->
            <div class="day-list">
              ${paginated.map(d => {
                const pc = PILLAR_COLORS[d.pillar];
                const isActive = state.selectedDay?.day === d.day;
                const phaseColor = PHASE_COLORS[d.phase];
                return `
                  <div class="day-row ${isActive ? "active" : ""}" onclick="generateScript(CONTENT_BANK[${d.day - 1}])">
                    <div class="day-number">
                      <div class="day-number-value">${d.day}</div>
                      <div class="day-label ui">day</div>
                    </div>
                    <div class="day-content">
                      <div class="day-hook">"${d.hook}"</div>
                      <div class="day-tags">
                        <span class="pill ui" style="background: ${pc.bg};">${pc.label}</span>
                        <span class="pill ui" style="background: ${phaseColor}cc;">${d.phase}</span>
                      </div>
                    </div>
                    <div class="day-arrow">›</div>
                  </div>
                `;
              }).join("")}
            </div>

            <!-- Pagination -->
            ${totalPages > 1 ? `
              <div class="pagination">
                <button class="btn btn-outline btn-small" onclick="prevPage()" ${state.page === 1 ? "disabled" : ""}>←</button>
                ${Array.from({ length: totalPages }, (_, i) => `
                  <button class="btn ${state.page === i + 1 ? "btn-pink" : "btn-outline"} btn-mini" onclick="goToPage(${i + 1})">${i + 1}</button>
                `).join("")}
                <button class="btn btn-outline btn-small" onclick="nextPage()" ${state.page === totalPages ? "disabled" : ""}>→</button>
              </div>
            ` : ""}
          </div>

          <!-- Main content -->
          <div class="main">
            ${!state.selectedDay && !state.loading ? `
              <div class="empty-state">
                <div class="empty-icon">✦</div>
                <h2 class="empty-title">Select a day to generate your script</h2>
                <p class="empty-description ui">
                  Choose any of your content days from the left panel. Claude will write a complete, on-brand script in your voice — hook, body, close, and format cues.
                </p>
                <div class="quick-buttons">
                  ${[1, 2, 3, 4, 5].map(n => `
                    <button class="btn btn-outline ui" onclick="generateScript(CONTENT_BANK[${n - 1}])">Try Day ${n}</button>
                  `).join("")}
                </div>
              </div>
            ` : ""}

            ${state.selectedDay ? `
              <div class="day-header">
                <div class="day-meta">
                  <span class="day-badge ui">Day ${state.selectedDay.day}</span>
                  <span class="pill ui" style="background: ${PILLAR_COLORS[state.selectedDay.pillar].bg};">${PILLAR_COLORS[state.selectedDay.pillar].label}</span>
                  <span class="pill ui" style="background: ${PHASE_COLORS[state.selectedDay.phase]}cc;">${state.selectedDay.phase}</span>
                  <span class="pill ui" style="background: rgba(200,180,210,0.2);">🎬 ${state.selectedDay.format}</span>
                </div>
                <h2 class="day-hook-title">"${state.selectedDay.hook}"</h2>
                <p class="day-concept ui">${state.selectedDay.concept}</p>
              </div>

              <div class="script-container">
                ${state.loading ? `
                  <div class="loading">
                    <div class="loading-dots">
                      <span class="loading-dot"></span>
                      <span class="loading-dot"></span>
                      <span class="loading-dot"></span>
                    </div>
                    <p class="loading-text ui">Writing your script...</p>
                  </div>
                ` : ""}

                ${state.error ? `
                  <div class="error-message">
                    <p class="error-text ui">${state.error}</p>
                    <button class="btn btn-pink" onclick="generateScript(state.selectedDay)">Try again</button>
                  </div>
                ` : ""}

                ${state.script && !state.loading ? `
                  <div class="script-actions">
                    <button class="btn btn-outline btn-small ui" onclick="generateScript(state.selectedDay)">↻ Regenerate</button>
                    <button class="btn btn-pink btn-small ui" onclick="copyScript()">${state.copied ? "✓ Copied!" : "Copy script"}</button>
                  </div>
                  <div class="script-block">${formatScriptHTML(state.script)}</div>
                  <div class="caption-box">
                    <div class="caption-label ui">Caption ready to use</div>
                    <div class="caption-text ui">${state.selectedDay.caption}</div>
                  </div>
                ` : ""}
              </div>

              ${state.script && !state.loading ? `
                <div class="script-nav">
                  ${state.selectedDay.day > 1 ? `
                    <button class="btn btn-outline ui" onclick="generateScript(CONTENT_BANK[${state.selectedDay.day - 2}])">← Day ${state.selectedDay.day - 1}</button>
                  ` : ""}
                  ${state.selectedDay.day < CONTENT_BANK.length ? `
                    <button class="btn btn-pink ui" onclick="generateScript(CONTENT_BANK[${state.selectedDay.day}])">Day ${state.selectedDay.day + 1} →</button>
                  ` : ""}
                </div>
              ` : ""}
            ` : ""}
          </div>
        </div>
      `;

      app.innerHTML = html;
    }

    // Event handlers
    function handleSearchChange(value) {
      state.search = value;
      state.page = 1;
      render();
    }

    function handlePillarChange(value) {
      state.filterPillar = value;
      state.page = 1;
      render();
    }

    function handlePhaseChange(value) {
      state.filterPhase = value;
      state.page = 1;
      render();
    }

    function prevPage() {
      state.page = Math.max(1, state.page - 1);
      render();
    }

    function nextPage() {
      const filtered = getFilteredDays();
      const totalPages = Math.ceil(filtered.length / state.PER_PAGE);
      state.page = Math.min(totalPages, state.page + 1);
      render();
    }

    function goToPage(page) {
      state.page = page;
      render();
    }

    // Initial render
    render();
  </script>
</body>
</html>
