                {error && (
                  <div style={{ textAlign: "center", padding: "40px 0" }}>
                    <p className="ui" style={{ color: "#e88090", marginBottom: 16 }}>{error}</p>
                    <button className="btn btn-pink" onClick={() => generateScript(selectedDay)}>Try again</button>
